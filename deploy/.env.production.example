# Production environment variables for VitaLink
# Copy this file to .env.production and fill in the values

PORT=3000
NODE_ENV=production
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/VitaLink?retryWrites=true&w=majority
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=1h

# S3-compatible storage (Filebase)
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Optional fail-closed HTTPS upload malware scanner
MALWARE_SCAN_ENABLED=false
MALWARE_SCAN_URL=
MALWARE_SCAN_AUTH_TOKEN=
MALWARE_SCAN_TIMEOUT_MS=10000

# Logging
LOG_LEVEL=info
LOKI_URL=
LOKI_USERNAME=
LOKI_PASSWORD=

# Admin seed (used by npm run seed:prod)
DEFAULT_ADMIN_LOGIN=
DEFAULT_ADMIN_PASSWORD=

# CORS (comma-separated origins)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
