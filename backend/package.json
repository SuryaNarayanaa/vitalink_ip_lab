{
  "name": "backend",
  "version": "1.0.0",
  "description": "A backend for the vitalink app in express and typescript",
  "main": "build/src/server.js",
  "scripts": {
    "dev": "nodemon --exec \"ts-node --require tsconfig-paths/register\" src/server.ts",
    "build": "tsc && tsc-alias",
    "vercel-build": "tsc && tsc-alias",
    "start": "node build/src/server.js",
    "test": "jest",
    "lint:openapi": "redocly lint docs/api/openapi.yaml",
    "ci": "npm run build && npm test",
    "seed": "ts-node --require tsconfig-paths/register src/scripts/createAdminUser.ts",
    "seed:prod": "node build/src/scripts/createAdminUser.js",
    "migrate:assigned-doctor-ids": "ts-node --require tsconfig-paths/register src/scripts/migrateAssignedDoctorIds.ts",
    "migrate:assigned-doctor-ids:prod": "node build/src/scripts/migrateAssignedDoctorIds.js",
    "migrate:patient-hospital-ids": "ts-node --require tsconfig-paths/register src/scripts/backfillPatientHospitalIds.ts",
    "migrate:patient-hospital-ids:prod": "node build/src/scripts/backfillPatientHospitalIds.js",
    "migrate:inr-critical-flags": "ts-node --require tsconfig-paths/register src/scripts/migrateInrCriticalFlags.ts",
    "migrate:inr-critical-flags:prod": "node build/src/scripts/migrateInrCriticalFlags.js",
    "migrate:doctor-update-notifications": "ts-node --require tsconfig-paths/register src/scripts/migrateDoctorChangeEventsToNotifications.ts",
    "migrate:doctor-update-notifications:prod": "node build/src/scripts/migrateDoctorChangeEventsToNotifications.js",
    "migrate:file-assets": "ts-node --require tsconfig-paths/register src/scripts/backfillFileAssets.ts",
    "migrate:file-assets:prod": "node build/src/scripts/backfillFileAssets.js",
    "migrate:device-tokens": "ts-node --require tsconfig-paths/register src/scripts/migrateDeviceTokenOwnership.ts",
    "migrate:device-tokens:prod": "node build/src/scripts/migrateDeviceTokenOwnership.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.80.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "9.1.5",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.6.0",
    "nodemon": "^3.1.11",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.3",
    "yaml": "^2.9.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@redocly/cli": "^2.38.0",
    "@types/axios": "^0.14.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.0",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-ui-express": "^4.1.8",
    "testcontainers": "^11.11.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
