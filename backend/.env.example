PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/VitaLink
JWT_SECRET=
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRY_DAYS=30
API_VERSION=v1
LEGACY_API_SUNSET_DATE=2026-10-01
CORS_ALLOWED_ORIGINS=
JSON_BODY_LIMIT=1mb
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
TRUST_PROXY=1
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
LOG_LEVEL=info
LOKI_URL=
LOKI_USERNAME=
LOKI_PASSWORD=
DEFAULT_ADMIN_LOGIN=
DEFAULT_ADMIN_PASSWORD=
API_DOCS_ENABLED=true
API_DOCS_PATH=/docs
API_DOCS_USERNAME=
API_DOCS_PASSWORD=

# Phone OTP challenge groundwork using Twilio Verify.
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS=3
ADMIN_TOTP_ENCRYPTION_KEY=
ADMIN_TOTP_CHALLENGE_EXPIRY_MINUTES=5
ADMIN_TOTP_MAX_ATTEMPTS=5
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_CHANNEL=sms
