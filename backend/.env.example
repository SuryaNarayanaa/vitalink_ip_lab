PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/VitaLink
JWT_SECRET=
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRY_DAYS=30
API_VERSION=v1
LEGACY_API_SUNSET_DATE=2026-10-01
CORS_ALLOWED_ORIGINS=
JSON_BODY_LIMIT=1mb
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
PASSWORD_EXPIRY_DAYS=90
PASSWORD_HISTORY_COUNT=5
TRUST_PROXY=1
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Required in staging/production. Set to the coordinated instant when all key-only writers are drained.
FILE_ASSET_LEGACY_CUTOFF_AT=
LOG_LEVEL=info
FCM_ENABLED=false
# Required and JSON-encoded only when FCM_ENABLED=true.
# Run docs/device-token-migration.md before enabling in an existing environment.
FIREBASE_SERVICE_ACCOUNT=
# BullMQ push-delivery worker. When empty, outbox rows still persist and the recovery poller drains them best-effort.
REDIS_URL=
NOTIFICATION_DELIVERY_ENABLED=true
NOTIFICATION_DELIVERY_MAX_ATTEMPTS=5
NOTIFICATION_DELIVERY_BASE_BACKOFF_MS=2000
NOTIFICATION_DELIVERY_RETENTION_DAYS=30
NOTIFICATION_DELIVERY_RECOVERY_INTERVAL_MS=30000
NOTIFICATION_DELIVERY_WORKER_CONCURRENCY=5
# Daily medication reminder schedule. Use an IANA timezone so container timezone
# changes do not alter the patient reminder window.
DOSAGE_REMINDER_CRON=0 9 * * *
DOSAGE_REMINDER_TIMEZONE=Asia/Kolkata
INR_REMINDER_INTERVAL_DAYS=30
NEXT_REVIEW_REMINDER_LEAD_DAYS=7
MISSED_DOSE_ESCALATION_WINDOW_DAYS=7
MISSED_DOSE_ESCALATION_THRESHOLD=2
LOKI_URL=
LOKI_USERNAME=
LOKI_PASSWORD=
DEFAULT_ADMIN_LOGIN=
DEFAULT_ADMIN_PASSWORD=
API_DOCS_ENABLED=true
API_DOCS_PATH=/docs
API_DOCS_USERNAME=
API_DOCS_PASSWORD=

# Phone OTP challenge settings using Twilio Verify.
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS=3
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_CHANNEL=sms
TWILIO_VERIFY_TEMPLATE_SID=
TWILIO_VERIFY_TEMPLATE_TTL_MINUTES=10

# Admin authenticator-app MFA.
ADMIN_TOTP_ENCRYPTION_KEY=
ADMIN_TOTP_CHALLENGE_EXPIRY_MINUTES=5
ADMIN_TOTP_MAX_ATTEMPTS=5
